<?xml version="1.0" encoding="utf-8"?>
<Config>
  <!-- Configurações dos Formulários -->
  <FormBackgroundColor>FFADD8E6</FormBackgroundColor>
  <!-- Configurações do MenuStrip -->
  <MenuStripBackgroundColor>FFFF80C0</MenuStripBackgroundColor>
  <GradientMenuEndColor>FF00FF80</GradientMenuEndColor>
  <MenuStripFontColor>FF00FF00</MenuStripFontColor>
  <!-- Configurações dos TextBox -->
  <TextBoxBackgroundColor>FF80FFFF</TextBoxBackgroundColor>
  <TextBoxFontColor>FF0000FF</TextBoxFontColor>
  <TextBoxBorderStyle>FixedSingle</TextBoxBorderStyle>
  <TextBoxFontFamily>Times New Roman</TextBoxFontFamily>
  <TextBoxFontSize>9,75</TextBoxFontSize>
  <TextBoxFontStyle>Regular</TextBoxFontStyle>
  <TextBoxMarginLeft>4</TextBoxMarginLeft>
  <TextBoxMarginTop>3</TextBoxMarginTop>
  <TextBoxMarginRight>4</TextBoxMarginRight>
  <TextBoxMarginBottom>3</TextBoxMarginBottom>
  <!-- Configurações dos botões -->
  <ButtonBackgroundColor>FFFF8000</ButtonBackgroundColor>
  <ButtonFontColor>FFFFFFFF</ButtonFontColor>
  <ButtonAutoSize>False</ButtonAutoSize>
  <ButtonAppearance>
    <BorderColor>FFFFFFC0</BorderColor>
    <MouseDownBackColor>FFC0C000</MouseDownBackColor>
    <MouseOverBackColor>FF008080</MouseOverBackColor>
  </ButtonAppearance>
  <ButtonCursor>Hand</ButtonCursor>
  <ButtonFontFamily>Times New Roman</ButtonFontFamily>
  <ButtonFontSize>12</ButtonFontSize>
  <ButtonFontStyle>Bold</ButtonFontStyle>
  <!-- Configurações das Label -->
  <LabelBackgroundColor>FFFFFF</LabelBackgroundColor>
  <LabelFontColor>FF000000</LabelFontColor>
  <LabelAutoSize>True</LabelAutoSize>
  <LabelFontFamily>Times New Roman</LabelFontFamily>
  <LabelFontSize>9,75</LabelFontSize>
  <LabelFontStyle>Bold</LabelFontStyle>
  <LabelMarginLeft>4</LabelMarginLeft>
  <LabelMarginTop>0</LabelMarginTop>
  <LabelMarginRight>4</LabelMarginRight>
  <LabelMarginBottom>0</LabelMarginBottom>
  <!-- Configurações dos Panel -->
  <PanelBackgroundColor>FFFFFF</PanelBackgroundColor>
  <!-- Configurações das Cores Degrade -->
  <GradientStartColor>FF8000FF</GradientStartColor>
  <GradientEndColor>FFFF8040</GradientEndColor>
</Config>